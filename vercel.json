{
  "functions": {
    "api/generate.js": {
      "maxDuration": 30
    },
    "api/config.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}